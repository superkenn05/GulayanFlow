
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Customer or user profile containing personal and contact details.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "profileImageUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "email"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Details of an order placed by a user.",
      "properties": {
        "id": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "object", "description": "Firestore Timestamp" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "pricePerUnit": { "type": "number" }
            }
          }
        }
      }
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "description": "Represents a classification for products.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" }
      }
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a single product item available in inventory.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "pricePerUnit": { "type": "number" },
        "unitOfMeasure": { "type": "string" },
        "currentStockQuantity": { "type": "number" },
        "lowStockThreshold": { "type": "number" },
        "isPopular": { "type": "boolean", "default": false },
        "nutritionalValues": {
          "type": "object",
          "properties": {
            "calories": { "type": "string" },
            "protein": { "type": "string" },
            "carbs": { "type": "string" },
            "fat": { "type": "string" }
          }
        }
      }
    },
    "StaffUser": {
      "title": "StaffUser",
      "type": "object",
      "description": "Internal staff member profiles.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "StockTransaction": {
      "title": "StockTransaction",
      "type": "object",
      "description": "Log of all stock movements.",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "staffUserId": { "type": "string" },
        "transactionType": { "type": "string" },
        "quantityChange": { "type": "number" },
        "transactionDate": { "type": "object" },
        "reason": { "type": "string" }
      }
    },
    "StoreConfig": {
      "title": "StoreConfig",
      "type": "object",
      "description": "Global settings for the store.",
      "properties": {
        "bannerUrl": { "type": "string", "format": "uri" },
        "storeName": { "type": "string" },
        "updatedAt": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": "UserProfile",
      "description": "Customer and client profiles."
    },
    "/userProfiles/{userId}/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders placed by a specific user."
    },
    "/staffUsers/{staffUserId}": {
      "schema": "StaffUser",
      "description": "Internal staff member profiles."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory products."
    },
    "/stockTransactions/{transactionId}": {
      "schema": "StockTransaction",
      "description": "Log of all stock movements."
    },
    "/storeConfigs/{configId}": {
      "schema": "StoreConfig",
      "description": "Global store configuration settings."
    }
  }
}
