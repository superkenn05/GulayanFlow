
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow access to global store configuration
    match /storeConfigs/{configId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Allow users to read their own notifications
    match /userProfiles/{userId}/notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;
    }

    // Explicitly allow collection group queries for 'orders'
    match /{path=**}/orders/{orderId} {
      allow read: if request.auth != null;
    }

    // Explicitly allow collection group queries and nested reads for 'reviews'
    match /products/{productId}/reviews/{reviewId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Allow collection group queries specifically for reviews
    match /{path=**}/reviews/{reviewId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // General rule for all other documents
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
