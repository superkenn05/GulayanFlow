rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GEMMA'S GULAYAN - SECURITY RULES PHILOSOPHY
     * 
     * Role-Based Access Control (RBAC) with path-based ownership.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getStaffRole() {
      let path = /databases/$(database)/documents/staffUsers/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'Guest';
    }

    function isAdmin() {
      return isSignedIn() && getStaffRole() == 'Admin';
    }

    function isStaff() {
      let role = getStaffRole();
      return isSignedIn() && (role == 'Staff' || role == 'Admin');
    }

    // --- Collection Rules ---

    match /staffUsers/{staffUserId} {
      // Allow self-read and creation for registration. 
      // Staff members can read each other to show names in transaction history.
      allow get: if isOwner(staffUserId) || isStaff();
      allow list: if isStaff();
      allow create: if isOwner(staffUserId);
      allow update: if isOwner(staffUserId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read, write: if isStaff();
    }

    match /products/{productId} {
      allow read, write: if isStaff();
    }

    match /stockTransactions/{transactionId} {
      allow get, list: if isStaff();
      allow create: if isStaff() && request.resource.data.staffUserId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- Global Deny ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
