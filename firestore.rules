rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. Global Superadmin Override ---
    // The master account always has full access to everything.
    // This is checked first to ensure zero lockouts for the shop owner.
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email == 'markken@gulayan.ph';
    }

    // --- 2. Staff Profiles ---
    match /staffUsers/{userId} {
      // Users can see and manage their own profiles.
      allow get, write: if request.auth != null && request.auth.uid == userId;
      // Admins and staff need to list the directory to see names/roles in the UI.
      allow list: if request.auth != null;
    }

    // --- 3. Operational Data (Categories, Products, Transactions) ---
    // These collections store shared data needed for the store to function.
    // 'read' covers both 'get' (single doc) and 'list' (queries/collection views).
    
    match /categories/{id} {
      allow read, write: if request.auth != null;
    }

    match /products/{id} {
      allow read, write: if request.auth != null;
    }

    match /stockTransactions/{id} {
      allow read, write: if request.auth != null;
    }
    
    // Explicitly handle collection-level listing for transactions to prevent query denials
    match /stockTransactions {
      allow list: if request.auth != null;
    }
  }
}