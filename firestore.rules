rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperadmin() {
      return isSignedIn() && (request.auth.token.email == 'markken@gulayan.ph');
    }

    function getStaffRole(uid) {
      let path = /databases/$(database)/documents/staffUsers/$(uid);
      return exists(path) ? get(path).data.role : 'Guest';
    }

    function isAdmin() {
      let role = getStaffRole(request.auth.uid);
      return isSignedIn() && (role == 'Admin' || role == 'Superadmin' || isSuperadmin());
    }

    // --- Collection Rules ---

    match /staffUsers/{staffId} {
      // 1. Owner Access: Users can always read and write their own profile
      allow read, write: if isSignedIn() && request.auth.uid == staffId;
      
      // 2. Superadmin Override: Full access for the main admin email
      allow read, write: if isSuperadmin();
      
      // 3. Admin Oversight: Admins can view the directory (list/get)
      allow read: if isAdmin();

      // 4. Activation: Allow temporary lookup for activation (unauthenticated get)
      allow get: if !isSignedIn() && staffId.size() > 5;
    }

    match /categories/{categoryId} {
      // Accessible to all authorized staff for operations
      allow read, write: if isSignedIn();
    }

    match /products/{productId} {
      // Accessible to all authorized staff for operations
      allow read, write: if isSignedIn();
    }

    match /stockTransactions/{transactionId} {
      // Explicitly allow list/get for signed in users
      allow read: if isSignedIn();
      // Allow creation and updates for movements
      allow create, update: if isSignedIn();
      // Delete is strictly restricted to Admins for audit integrity
      allow delete: if isAdmin();
    }

    // Global deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}