rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GEMMA'S GULAYAN - SECURITY RULES PHILOSOPHY
     * 
     * Core Philosophy:
     * This ruleset implements a Role-Based Access Control (RBAC) model combined with 
     * path-based ownership. It is designed for an inventory management system where 
     * authenticated staff members manage shared resources (Products, Categories, Transactions).
     *
     * Data Structure:
     * The database uses a flat, top-level collection structure to ensure authorization 
     * independence and efficient queries.
     * - /staffUsers: Personal profiles and role definitions.
     * - /categories: Shared product classifications.
     * - /products: Shared inventory items.
     * - /stockTransactions: Audit logs of all stock movements.
     *
     * Key Security Decisions:
     * 1. DBAC (Database Access Control): User roles ('Admin', 'Staff') are stored directly 
     *    on the user's document in /staffUsers and used to gate access to global collections.
     * 2. Path-Based Ownership: Users have exclusive access to their own profile data 
     *    based on their Firebase Auth UID.
     * 3. Relational Integrity: On creation of transactions, the rules enforce that the 
     *    'staffUserId' matches the actual authenticated user to ensure audit log accuracy.
     * 4. Prototyping Flexibility: Schema validation (types, required fields) is omitted 
     *    to allow rapid UI iteration, focusing strictly on identity and role authorization.
     */

    // --- Helper Functions ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the provided ID matches the authenticated user's UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Retrieves the role of the authenticated staff member from their profile. */
    function getStaffRole() {
      return get(/databases/$(database)/documents/staffUsers/$(request.auth.uid)).data.role;
    }

    /** Checks if the user has the 'Admin' role. */
    function isAdmin() {
      return isSignedIn() && getStaffRole() == 'Admin';
    }

    /** Checks if the user is any authenticated staff member (Staff or Admin). */
    function isStaff() {
      return isSignedIn() && (getStaffRole() == 'Staff' || getStaffRole() == 'Admin');
    }

    /** Combines ownership and existence checks for destructive operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for staff member profiles. Users can manage their own data; Admins can view/manage all.
     * @path /staffUsers/{staffUserId}
     * @allow (get) If user is the owner or an Admin.
     * @deny (create) If the staffUserId does not match the auth UID.
     * @principle Enforces path-based ownership for sensitive user profiles.
     */
    match /staffUsers/{staffUserId} {
      allow get: if isOwner(staffUserId) || isAdmin();
      allow list: if isAdmin() || isOwner(staffUserId);
      allow create: if isOwner(staffUserId) && request.resource.data.id == staffUserId;
      allow update: if (isExistingOwner(staffUserId) || isAdmin()) && request.resource.data.id == staffUserId;
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for product categories. Accessible to all authorized staff.
     * @path /categories/{categoryId}
     * @allow (list) If user has 'Staff' or 'Admin' role.
     * @deny (write) If user is not signed in or lacks a staff role.
     * @principle Role-based access for shared operational metadata.
     */
    match /categories/{categoryId} {
      allow get, list: if isStaff();
      allow create: if isStaff();
      allow update: if resource != null && isStaff();
      allow delete: if resource != null && isStaff();
    }

    /**
     * @description Rules for inventory products. Accessible to all authorized staff.
     * @path /products/{productId}
     * @allow (update) By any staff member to adjust stock levels.
     * @deny (read) By unauthenticated or non-staff users.
     * @principle Homogeneous access for staff members to shared inventory data.
     */
    match /products/{productId} {
      allow get, list: if isStaff();
      allow create: if isStaff();
      allow update: if resource != null && isStaff();
      allow delete: if resource != null && isStaff();
    }

    /**
     * @description Rules for stock movement logs. Ensures audit trail integrity.
     * @path /stockTransactions/{transactionId}
     * @allow (create) If the staffUserId in the data matches the authenticated user.
     * @deny (update) Prevent modification of historical transaction records (Admin only).
     * @principle Relational integrity and non-repudiation for audit logs.
     */
    match /stockTransactions/{transactionId} {
      allow get, list: if isStaff();
      allow create: if isStaff() && request.resource.data.staffUserId == request.auth.uid;
      
      // Usually, transactions are immutable for audit purposes. 
      // We restrict updates/deletes to Admins or deny entirely.
      allow update: if resource != null && isAdmin();
      allow delete: if resource != null && isAdmin();
    }

    // --- Global Deny ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}