rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GEMMA'S GULAYAN - SECURITY RULES
     * 
     * Hierarchy: Superadmin (markken@gulayan.ph) > Admin > Staff
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getStaffRole() {
      let path = /databases/$(database)/documents/staffUsers/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'Guest';
    }

    function isSuperadmin() {
      return isSignedIn() && request.auth.token.email == 'markken@gulayan.ph';
    }

    function isAdmin() {
      let role = getStaffRole();
      return isSignedIn() && (role == 'Admin' || role == 'Superadmin' || isSuperadmin());
    }

    // --- Collection Rules ---

    match /staffUsers/{staffUserId} {
      // Users can always read their own profile (crucial for useDoc and identification)
      allow get: if isSignedIn() && request.auth.uid == staffUserId;
      
      // Users can update their own basic profile (name, email)
      allow update: if isSignedIn() && request.auth.uid == staffUserId;
      
      // Superadmin has full read/write access to everything in this collection
      allow read, write: if isSuperadmin();
      
      // Admins can view the directory (list) but not modify it
      allow list: if isAdmin();

      // Allow temporary lookup for activation (unauthenticated get for email-based IDs)
      // This is safe as long as we only allow 'get' and not 'list'
      allow get: if !isSignedIn() && staffUserId.size() > 5;
    }

    match /categories/{categoryId} {
      // Accessible to all authorized staff for operations
      allow read, write: if isSignedIn();
    }

    match /products/{productId} {
      // Accessible to all authorized staff for operations
      allow read, write: if isSignedIn();
    }

    match /stockTransactions/{transactionId} {
      // Accessible to all authorized staff for operations
      allow read, create, update: if isSignedIn();
      // Delete is restricted to Admins for audit integrity
      allow delete: if isAdmin();
    }

    // Global deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}