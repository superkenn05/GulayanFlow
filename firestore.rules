rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'markken@gulayan.ph';
    }

    // Staff Users
    match /staffUsers/{userId} {
      allow get, write: if request.auth.uid == userId || isSuperAdmin();
      allow list: if isSignedIn();
    }

    // Categories
    match /categories/{id} {
      allow read, write: if isSignedIn();
    }

    // Products
    match /products/{id} {
      allow read, write: if isSignedIn();
    }

    // Stock Transactions
    match /stockTransactions/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }
  }
}