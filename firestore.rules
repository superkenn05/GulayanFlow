rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Superadmin Override ---
    // The master account always has full access to everything.
    // This is checked first for maximum reliability.
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email == 'markken@gulayan.ph';
    }

    // --- Staff Users ---
    match /staffUsers/{userId} {
      // Users can see and manage their own profiles.
      allow get, write: if request.auth != null && request.auth.uid == userId;
      // Admins and staff need to list the directory for names and roles in the UI.
      allow list: if request.auth != null;
    }

    // --- Product Categories ---
    match /categories/{categoryId} {
      // Shared operational data accessible to all authorized staff.
      allow read, write: if request.auth != null;
    }

    // --- Products ---
    match /products/{productId} {
      // Shared operational data accessible to all authorized staff.
      allow read, write: if request.auth != null;
    }

    // --- Stock Transactions ---
    match /stockTransactions/{transactionId} {
      // Essential for Activity Feeds and Orders list. 
      // 'read' covers both 'get' and 'list'.
      allow read: if request.auth != null;
      // Any staff can record stock movement.
      allow create, update: if request.auth != null;
      // Deletion is restricted to Superadmin (handled by the global match above).
    }
  }
}