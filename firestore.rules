rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GEMMA'S GULAYAN - SECURITY RULES
     * 
     * Hierarchy: Superadmin > Admin > Staff
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getStaffRole() {
      let path = /databases/$(database)/documents/staffUsers/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'Guest';
    }

    function isSuperadmin() {
      return isSignedIn() && (getStaffRole() == 'Superadmin' || request.auth.token.email == 'markken@gulayan.ph');
    }

    function isAdmin() {
      let role = getStaffRole();
      return isSignedIn() && (role == 'Admin' || role == 'Superadmin' || request.auth.token.email == 'markken@gulayan.ph');
    }

    function isStaff() {
      let role = getStaffRole();
      return isSignedIn() && (role == 'Staff' || role == 'Admin' || role == 'Superadmin' || request.auth.token.email == 'markken@gulayan.ph');
    }

    // --- Collection Rules ---

    match /staffUsers/{staffUserId} {
      // Users can always read/update their own basic profile
      allow get, update: if isSignedIn() && request.auth.uid == staffUserId;
      
      // Superadmins can manage all users (Admins and Staff)
      allow read, write: if isSuperadmin();
      
      // Admins can view the directory but not delete/promote other admins
      allow list, get: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /stockTransactions/{transactionId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // Global deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}