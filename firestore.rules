rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GEMMA'S GULAYAN - SECURITY RULES
     * 
     * Robust role-based access control focusing on authorization independence.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getStaffRole() {
      let path = /databases/$(database)/documents/staffUsers/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'Guest';
    }

    function isAdmin() {
      return isSignedIn() && getStaffRole() == 'Admin';
    }

    function isStaff() {
      let role = getStaffRole();
      return isSignedIn() && (role == 'Staff' || role == 'Admin');
    }

    // --- Collection Rules ---

    match /staffUsers/{staffUserId} {
      // Allow users to manage their own profiles (crucial for AuthInitializer)
      allow get, create, update: if isSignedIn() && request.auth.uid == staffUserId;
      
      // Allow staff to view directory (e.g., for transaction attribution)
      allow list: if isStaff();
      allow get: if isStaff();
      
      // Admins can delete staff
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      // Allow staff to manage categories
      allow read, write: if isStaff();
    }

    match /products/{productId} {
      // Allow staff to manage products
      allow read, write: if isStaff();
    }

    match /stockTransactions/{transactionId} {
      // Allow staff to view transactions
      allow read: if isStaff();
      
      // Allow staff to record their own transactions
      allow create: if isStaff() && request.resource.data.staffUserId == request.auth.uid;
      
      // Admins can modify/delete history (for corrections)
      allow update, delete: if isAdmin();
    }

    // Global deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}