rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GEMMA'S GULAYAN - SECURITY RULES
     * 
     * Robust role-based access control.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getStaffDoc() {
      return get(/databases/$(database)/documents/staffUsers/$(request.auth.uid));
    }

    function getStaffRole() {
      let path = /databases/$(database)/documents/staffUsers/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'Guest';
    }

    function isAdmin() {
      return isSignedIn() && getStaffRole() == 'Admin';
    }

    function isStaff() {
      let role = getStaffRole();
      return isSignedIn() && (role == 'Staff' || role == 'Admin');
    }

    // --- Collection Rules ---

    match /staffUsers/{staffUserId} {
      // Allow users to manage their own profiles
      allow get, create, update: if isSignedIn() && request.auth.uid == staffUserId;
      
      // Allow searching for placeholder docs during activation (checked by email)
      allow list: if isSignedIn();
      allow get: if isSignedIn();

      // Admins can manage all staff profiles
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /stockTransactions/{transactionId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // Global deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}