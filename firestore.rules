rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperadmin() {
      return isSignedIn() && request.auth.token.email == 'markken@gulayan.ph';
    }

    // --- Global Superadmin Override ---
    // This is placed at the top and covers every path in the database.
    // This ensures that the Superadmin (markken@gulayan.ph) always has full access.
    match /{document=**} {
      allow read, write: if isSuperadmin();
    }

    // --- Collection Specific Rules ---

    match /staffUsers/{staffId} {
      // Any signed in staff can list the directory (needed for audit views and history displays)
      allow list: if isSignedIn();
      // Users can manage their own profile
      allow get, write: if isSignedIn() && request.auth.uid == staffId;
    }

    match /categories/{categoryId} {
      // Operational data accessible to all authorized staff for day-to-day work
      allow read, write: if isSignedIn();
    }

    match /products/{productId} {
      // Operational data accessible to all authorized staff
      allow read, write: if isSignedIn();
    }

    match /stockTransactions/{transactionId} {
      // Essential for Dashboard activity feeds and Order History views
      // 'read' covers both 'get' (single document) and 'list' (collection queries)
      allow read: if isSignedIn();
      // Allow any staff member to log new movements
      allow create, update: if isSignedIn();
      // Deletions are a sensitive audit-trail operation and remain restricted to Superadmin via the global rule
    }
  }
}