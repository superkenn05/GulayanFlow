rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GEMMA'S GULAYAN - SECURITY RULES
     * 
     * Hierarchy: Superadmin (markken@gulayan.ph) > Admin > Staff
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getStaffRole() {
      let path = /databases/$(database)/documents/staffUsers/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'Guest';
    }

    function isSuperadmin() {
      return isSignedIn() && request.auth.token.email == 'markken@gulayan.ph';
    }

    function isAdmin() {
      let role = getStaffRole();
      return isSignedIn() && (role == 'Admin' || role == 'Superadmin' || isSuperadmin());
    }

    // --- Collection Rules ---

    match /staffUsers/{staffUserId} {
      // Allow GET for identification (needed for profile page and sidebar)
      allow get: if isSignedIn();
      
      // Users can update their own basic profile
      allow update: if isSignedIn() && request.auth.uid == staffUserId;
      
      // Only the Superadmin can manage the directory and assign roles/status
      allow read, write: if isSuperadmin();
      
      // Admins can view the directory but not modify it
      allow list: if isAdmin();
    }

    match /categories/{categoryId} {
      // Restricted to Admin and Superadmin only. Staff removed.
      allow read, write: if isAdmin();
    }

    match /products/{productId} {
      // Restricted to Admin and Superadmin only. Staff removed.
      allow read, write: if isAdmin();
    }

    match /stockTransactions/{transactionId} {
      // Restricted to Admin and Superadmin only. Staff removed.
      allow read, create, update, delete: if isAdmin();
    }

    // Global deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
