rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperadmin() {
      return isSignedIn() && request.auth.token.email == 'markken@gulayan.ph';
    }

    // --- Collection Rules ---

    // Superadmin has full access to everything by default
    match /{document=**} {
      allow read, write: if isSuperadmin();
    }

    match /staffUsers/{staffId} {
      // Users can always read and update their own profile
      allow read, write: if isSignedIn() && request.auth.uid == staffId;
      // Allow directory listing for authenticated staff
      allow list: if isSignedIn();
    }

    match /categories/{categoryId} {
      // Accessible to all authorized staff for operations
      allow read, write: if isSignedIn();
    }

    match /products/{productId} {
      // Accessible to all authorized staff for operations
      allow read, write: if isSignedIn();
    }

    match /stockTransactions/{transactionId} {
      // Allow reading history for all signed in staff
      allow read: if isSignedIn();
      // Allow logging movements
      allow create, update: if isSignedIn();
      // Deletion is restricted to Superadmin via the global rule above
    }
  }
}